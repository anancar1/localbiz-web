<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ business.name }} — {{ business.category }} en {{ city }}, {{ region }}. {{ business.description[:120] if business.description else '' }}">
    <title>{{ business.name }} — {{ business.category | capitalize }} en {{ city }}</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
    <style>
        :root {
            --warm-black: #222222;
            --text-secondary: #6a6a6a;
            --text-muted: #9ca3af;
            --cat-color: #d97706;
            --surface: #ffffff;
            --surface-alt: #fafaf9;
            --surface-warm: #fef7ed;
            --border: #e5e7eb;
            --card-shadow: 0 0 0 1px rgba(0,0,0,0.03), 0 2px 8px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
            --card-hover: 0 0 0 1px rgba(0,0,0,0.05), 0 4px 20px rgba(0,0,0,0.10);
            --radius-sm: 10px;
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-full: 999px;
            --font-serif: 'Playfair Display', Georgia, serif;
        }
        {% if business.category == 'restaurante' %}
            :root { --cat-color: #c2410c; --cat-light: #fff7ed; }
        {% elif business.category in ['peluqueria', 'barberia'] %}
            :root { --cat-color: #7c3aed; --cat-light: #f5f3ff; }
        {% elif business.category == 'electricista' %}
            :root { --cat-color: #d97706; --cat-light: #fffbeb; }
        {% endif %}
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
        body{font-family:'DM Sans',system-ui,-apple-system,sans-serif;font-size:1.05rem;color:var(--warm-black);background:var(--surface);line-height:1.65}
        img{max-width:100%;display:block}
        a{color:inherit;text-decoration:none}
        .container{max-width:1100px;margin:0 auto;padding:0 20px}

        /* HEADER */
        .header{background:rgba(255,255,255,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;border-bottom:1px solid transparent;transition:border-color 0.3s}
        .header.scrolled{border-bottom-color:var(--border)}
        .header__inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:68px;padding:0 20px}
        .header__logo{font-size:1.2rem;font-weight:700;color:var(--warm-black);display:flex;align-items:center;gap:8px}
        .header__logo-dot{width:8px;height:8px;background:var(--cat-color);border-radius:50%}
        .header__cta{background:var(--cat-color);color:#fff;padding:10px 22px;border-radius:var(--radius-full);font-weight:600;font-size:0.9rem;transition:transform 0.15s,box-shadow 0.15s}
        .header__cta:hover{transform:scale(1.03);box-shadow:0 4px 16px rgba(0,0,0,0.15)}

        /* HERO */
        .hero{position:relative;min-height:520px;display:flex;align-items:center;justify-content:center;text-align:center;color:#fff;overflow:hidden;background:#1a1a1a}
        .hero__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.55}
        .hero__overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.25) 0%,rgba(0,0,0,0.55) 50%,rgba(0,0,0,0.85) 100%)}
        .hero__inner{position:relative;z-index:2;max-width:700px;padding:40px 20px}
        .hero__badge{display:inline-block;background:var(--cat-color);padding:6px 18px;border-radius:var(--radius-full);font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:16px}
        .hero__title{font-family:var(--font-serif);font-size:clamp(2.2rem,5vw,3.5rem);font-weight:700;line-height:1.15;margin-bottom:8px;letter-spacing:-0.01em}
        .hero__rating{display:inline-flex;align-items:center;gap:6px;margin-bottom:12px;font-size:0.95rem}
        .hero__stars{color:#fbbf24;letter-spacing:1px}
        .hero__address{color:rgba(255,255,255,0.8);font-size:0.95rem;margin-bottom:24px}
        .hero__ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
        .btn{padding:13px 28px;border-radius:var(--radius-full);font-weight:600;font-size:0.95rem;transition:all 0.2s;cursor:pointer;display:inline-flex;align-items:center;gap:8px}
        .btn--primary{background:#fff;color:var(--warm-black)}
        .btn--primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.2)}
        .btn--outline{border:2px solid rgba(255,255,255,0.6);color:#fff}
        .btn--outline:hover{background:rgba(255,255,255,0.1);border-color:#fff}

        /* OPEN BADGE */
        .open-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--radius-full);font-size:0.8rem;font-weight:600;margin-top:8px}
        .open-badge--open{background:#dcfce7;color:#166534}
        .open-badge--closed{background:#fee2e2;color:#991b1b}
        .open-badge__dot{width:7px;height:7px;border-radius:50%}
        .open-badge--open .open-badge__dot{background:#16a34a}
        .open-badge--closed .open-badge__dot{background:#dc2626}

        /* SECTIONS */
        .section{padding:64px 0}
        .section--alt{background:var(--surface-alt)}
        .section__header{text-align:center;margin-bottom:40px}
        .section__label{display:inline-block;color:var(--cat-color);font-weight:600;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px}
        .section__title{font-family:var(--font-serif);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;letter-spacing:-0.01em;color:var(--warm-black)}
        .section__subtitle{color:var(--text-secondary);max-width:550px;margin:8px auto 0;font-size:1.05rem}

        /* ABOUT */
        .about{max-width:680px;margin:0 auto;text-align:center}
        .about__text{color:var(--text-secondary);font-size:1.1rem;line-height:1.8}

        /* MENU */
        .menu-category{margin-bottom:48px}
        .menu-category:last-child{margin-bottom:0}
        .menu-category__title{font-family:var(--font-serif);font-size:1.5rem;font-weight:700;margin-bottom:4px;color:var(--warm-black);padding-bottom:10px;border-bottom:3px solid var(--cat-color)}
        .menu-category__desc{color:var(--text-secondary);font-size:0.9rem;margin-bottom:20px}
        .menu-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px}
        .menu-card{background:var(--surface);border-radius:var(--radius-md);overflow:hidden;box-shadow:var(--card-shadow);transition:transform 0.2s,box-shadow 0.25s}
        .menu-card:hover{transform:translateY(-4px);box-shadow:var(--card-hover)}
        .menu-card__image{width:100%;height:200px;object-fit:cover}
        .menu-card__body{padding:18px 20px 20px}
        .menu-card__name{font-size:1.1rem;font-weight:700;margin-bottom:6px;display:flex;justify-content:space-between;align-items:start}
        .menu-card__price{color:var(--cat-color);font-weight:700;font-size:1.1rem;white-space:nowrap;margin-left:12px}
        .menu-card__desc{color:var(--text-secondary);font-size:0.9rem;line-height:1.6}

        /* GALLERY */
        .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
        .gallery-grid__item{aspect-ratio:4/3;overflow:hidden;border-radius:var(--radius-sm);cursor:pointer}
        .gallery-grid__img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s}
        .gallery-grid__item:hover .gallery-grid__img{transform:scale(1.06)}
        .gallery-grid__item:first-child{grid-column:span 2;grid-row:span 2;aspect-ratio:auto}

        /* INFO */
        .info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px}
        .info-card{background:var(--surface);padding:20px 24px;border-radius:var(--radius-md);box-shadow:var(--card-shadow);display:flex;align-items:start;gap:14px}
        .info-card__icon{flex-shrink:0;width:40px;height:40px;background:var(--cat-light);border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:var(--cat-color)}
        .info-card__content{min-width:0}
        .info-card__label{font-size:0.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px}
        .info-card__value{font-weight:600;font-size:0.95rem;word-break:break-word}
        .info-card__link{color:var(--cat-color);font-weight:600;font-size:0.85rem;margin-top:4px;display:inline-block}

        /* HOURS */
        .hours{max-width:440px;margin:0 auto}
        .hours__row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
        .hours__row:last-child{border-bottom:none}
        .hours__day{font-weight:600;font-size:0.95rem}
        .hours__time{color:var(--text-secondary);font-size:0.9rem}
        .hours__today{background:var(--cat-light);margin:0 -12px;padding:10px 12px;border-radius:var(--radius-sm)}

        /* FAQ */
        .faq{max-width:650px;margin:0 auto}
        .faq__item{padding:18px 0;border-bottom:1px solid var(--border)}
        .faq__item:last-child{border-bottom:none}
        .faq__q{font-weight:600;font-size:1.05rem;margin-bottom:6px}
        .faq__a{color:var(--text-secondary);font-size:0.95rem;line-height:1.7}

        /* CTA */
        .cta-section{background:var(--cat-color);color:#fff;text-align:center;padding:72px 20px}
        .cta-section__title{font-family:var(--font-serif);font-size:clamp(1.5rem,4vw,2.2rem);font-weight:700;margin-bottom:12px;letter-spacing:-0.01em}
        .cta-section__text{opacity:0.9;font-size:1.1rem;max-width:500px;margin:0 auto 24px}
        .cta-section .btn--primary{background:#fff;color:var(--cat-color);font-size:1.05rem;padding:15px 36px}

        /* FOOTER */
        .footer{background:#1a1a1a;color:rgba(255,255,255,0.5);padding:32px 20px;text-align:center;font-size:0.85rem}
        .footer__link{color:rgba(255,255,255,0.7);text-decoration:underline;text-underline-offset:3px}

        /* FLOATING */
        .fab{position:fixed;bottom:24px;right:24px;z-index:999;width:54px;height:54px;border-radius:50%;background:#25d366;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:0 4px 20px rgba(37,211,102,0.4);transition:transform 0.2s}
        .fab:hover{transform:scale(1.1)}

        @media(max-width:768px){
            .hero{min-height:400px}
            .menu-grid{grid-template-columns:1fr}
            .gallery-grid{grid-template-columns:repeat(2,1fr)}
            .gallery-grid__item:first-child{grid-column:span 1;grid-row:span 1;aspect-ratio:4/3}
            .info-grid{grid-template-columns:1fr}
        }
        @media(max-width:480px){
            .gallery-grid{grid-template-columns:1fr}
            .hero__ctas{flex-direction:column;align-items:center}
        }
    </style>
</head>
<body>

<header class="header" id="header">
    <div class="header__inner">
        <a href="#" class="header__logo"><span class="header__logo-dot"></span>{{ business.name }}</a>
        {% if business.phone %}
        <a href="tel:{{ business.phone }}" class="header__cta">Llamar</a>
        {% endif %}
    </div>
</header>

<section class="hero">
    {% if business.photos %}
    <img src="{{ business.photos[0] }}" alt="" class="hero__bg" loading="eager">
    {% endif %}
    <div class="hero__overlay"></div>
    <div class="hero__inner">
        <span class="hero__badge">{{ business.category | capitalize }}</span>
        <h1 class="hero__title">{{ business.name }}</h1>
        {% if business.rating %}
        <div class="hero__rating">
            <span class="hero__stars">★ {{ business.rating }} / 5</span>
            <strong>{{ business.rating }}</strong>
            <span style="opacity:0.7">· {{ business.reviews }} reseñas</span>
        </div>
        {% endif %}
        <p class="hero__address">{{ business.address or city + ', ' + region }}</p>
        <div class="hero__ctas">
            {% if business.phone %}
            <a href="tel:{{ business.phone }}" class="btn btn--primary">📞 {{ business.phone }}</a>
            {% endif %}
            {% if business.maps_url %}
            <a href="{{ business.maps_url }}" target="_blank" rel="noopener" class="btn btn--outline">📍 Cómo llegar</a>
            {% endif %}
        </div>
    </div>
</section>

{% if business.description %}
<section class="section">
    <div class="container">
        <div class="about">
            <p class="about__text">{{ business.description }}</p>
        </div>
    </div>
</section>
{% endif %}

{% if business.menu_categories %}
<section class="section section--alt" id="carta">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Carta</span>
            <h2 class="section__title">Lo que se come aquí</h2>
            <p class="section__subtitle">Cocina de mercado, recetas de familia y producto de la comarca. Sin atajos.</p>
        </div>
        {% for cat in business.menu_categories %}
        <div class="menu-category">
            <h3 class="menu-category__title">{{ cat.name }}</h3>
            <div class="menu-grid">
                {% for item in cat['items'] %}
                <div class="menu-card">
                    {% if item.image %}<img src="{{ item.image }}" alt="{{ item.name }}" class="menu-card__image" loading="lazy">{% endif %}
                    <div class="menu-card__body">
                        <div class="menu-card__name">
                            {{ item.name }}
                            {% if item.price %}<span class="menu-card__price">{{ item.price }}€</span>{% endif %}
                        </div>
                        <p class="menu-card__desc">{{ item.description }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% elif business.menu_items %}
<section class="section section--alt" id="carta">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Carta</span>
            <h2 class="section__title">Nuestra Carta</h2>
            <p class="section__subtitle">Descubre los platos que nos hacen únicos</p>
        </div>
        <div class="menu-grid">
            {% for item in business.menu_items %}
            <div class="menu-card">
                {% if item.image %}<img src="{{ item.image }}" alt="{{ item.name }}" class="menu-card__image" loading="lazy">{% endif %}
                <div class="menu-card__body">
                    <div class="menu-card__name">
                        {{ item.name }}
                        {% if item.price %}<span class="menu-card__price">{{ item.price }}€</span>{% endif %}
                    </div>
                    <p class="menu-card__desc">{{ item.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if business.services %}
<section class="section section--alt" id="servicios">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Servicios</span>
            <h2 class="section__title">Lo que hacemos</h2>
            <p class="section__subtitle">Especialistas en lo que necesitas, con la garantía de toda una vida de oficio</p>
        </div>
        <div class="menu-grid">
            {% for svc in business.services %}
            <div class="menu-card">
                <div class="menu-card__body">
                    <div class="menu-card__name" style="align-items:center">
                        <span style="display:flex;align-items:center;gap:10px">{{ svc.icon or '✦' }} {{ svc.name }}</span>
                        {% if svc.price %}<span class="menu-card__price">{{ svc.price }}</span>{% endif %}
                    </div>
                    <p class="menu-card__desc">{{ svc.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if business.photos %}
<section class="section" id="galeria">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Galería</span>
            <h2 class="section__title">El espacio</h2>
            <p class="section__subtitle">Ven a conocerlo en persona, pero mientras tanto...</p>
        </div>
        <div class="gallery-grid">
            {% for photo in business.photos[:7] %}
            <div class="gallery-grid__item">
                <img src="{{ photo }}" alt="{{ business.name }} — foto {{ loop.index }}" class="gallery-grid__img" loading="lazy">
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<section class="section section--alt">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Info</span>
            <h2 class="section__title">Datos útiles</h2>
        </div>
        <div class="info-grid">
            {% if business.phone %}
            <div class="info-card">
                <div class="info-card__icon">📞</div>
                <div class="info-card__content">
                    <div class="info-card__label">Teléfono</div>
                    <div class="info-card__value">{{ business.phone }}</div>
                    <a href="tel:{{ business.phone }}" class="info-card__link">Llamar →</a>
                </div>
            </div>
            {% endif %}
            {% if business.address %}
            <div class="info-card">
                <div class="info-card__icon">📍</div>
                <div class="info-card__content">
                    <div class="info-card__label">Dirección</div>
                    <div class="info-card__value">{{ business.address }}</div>
                    {% if business.maps_url %}
                    <a href="{{ business.maps_url }}" target="_blank" rel="noopener" class="info-card__link">Google Maps →</a>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            {% if business.rating %}
            <div class="info-card">
                <div class="info-card__icon">⭐</div>
                <div class="info-card__content">
                    <div class="info-card__label">Valoración</div>
                    <div class="info-card__value">{{ business.rating }} / 5</div>
                    <span style="font-size:0.85rem;color:var(--text-secondary)">{{ business.reviews }} reseñas en Google</span>
                </div>
            </div>
            {% endif %}
            <div class="info-card">
                <div class="info-card__icon">🏷️</div>
                <div class="info-card__content">
                    <div class="info-card__label">Categoría</div>
                    <div class="info-card__value">{{ business.category | capitalize }}</div>
                    {% if business.type %}<span style="font-size:0.85rem;color:var(--text-secondary)">{{ business.type }}</span>{% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{% if business.hours %}
<section class="section" id="horario">
    <div class="container">
        <div class="section__header">
            <span class="section__label">Horario</span>
            <h2 class="section__title">Cuándo abrimos</h2>
        </div>
        <div class="hours">
            {% for entry in business.hours %}
            <div class="hours__row{% if loop.index == 1 %} hours__today{% endif %}">
                <span class="hours__day">{{ entry }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if business.faq %}
<section class="section section--alt" id="faq">
    <div class="container">
        <div class="section__header">
            <h2 class="section__title">Preguntas frecuentes</h2>
        </div>
        <div class="faq">
            {% for fq in business.faq %}
            <div class="faq__item">
                <p class="faq__q">{{ fq.question }}</p>
                <p class="faq__a">{{ fq.answer }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<section class="cta-section">
    <h2 class="cta-section__title">¿Vienes a comer?</h2>
    <p class="cta-section__text">Llama y reserva tu mesa. O pásate sin avisar, que aquí siempre cabe uno más.</p>
    {% if business.phone %}
    <a href="tel:{{ business.phone }}" class="btn btn--primary">{{ business.phone }}</a>
    {% endif %}
</section>

<footer class="footer">
    <p>{{ business.name }} · {{ business.address or city + ', ' + region }}</p>
    {% if business.maps_url %}
    <p style="margin-top:8px"><a href="{{ business.maps_url }}" target="_blank" rel="noopener" class="footer__link">Abrir en Google Maps</a></p>
    {% endif %}
</footer>

{% if business.phone %}
<a href="https://wa.me/{{ business.phone | replace('+', '') | replace(' ', '') }}" target="_blank" rel="noopener" class="fab" aria-label="WhatsApp">💬</a>
{% endif %}

</body>
</html>